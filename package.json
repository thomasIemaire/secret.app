{
  "name": "sardine",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "lint": "ng lint",
    "serve": "npm run lint && ng serve",
    "build": "npm run lint && ng build",
    "serve-prod": "npm run lint && ng serve --configuration production",
    "build-prod": "npm run lint && ng build --configuration production --output-hashing=all",
    "storybook": "ng run Sardine:storybook",
    "build-storybook": "ng run Sardine:build-storybook"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.1.2",
    "@angular/compiler": "^20.1.2",
    "@angular/core": "^20.1.2",
    "@angular/forms": "^20.1.2",
    "@angular/platform-browser": "^20.1.2",
    "@angular/router": "^20.1.2",
    "@primeuix/themes": "^1.2.1",
    "primeicons": "^7.0.0",
    "primeng": "^20.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.1.2",
    "@angular/build": "^20.1.2",
    "@angular/cli": "^20.1.2",
    "@angular/compiler-cli": "^20.1.2",
    "@storybook/addon-docs": "^9.0.18",
    "@storybook/angular": "^9.0.18",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "20.1.1",
    "css-loader": "^7.1.2",
    "eslint": "^9.29.0",
    "eslint-plugin-storybook": "^9.0.18",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "sass": "^1.89.2",
    "sass-loader": "^16.0.5",
    "storybook": "^9.0.18",
    "style-loader": "^4.0.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "8.34.1"
  }
}